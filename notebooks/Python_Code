import pandas as pd
import numpy as np
from google.cloud import bigquery

# 1. Setup the connection with your REFINED table
client = bigquery.Client()
# Updated to your new production table
table_id = "pay-errors.otpay.top_5_agencies_labels"

# 2. Pull the pre-flagged violators
# Using the column we engineered in Phase 2
query = f"""
SELECT
    agency_name,
    title_description,
    base_salary,
    total_ot_paid,
    ot_hours,
    work_location_borough,
    agency_start_date,
    leave_status
FROM `{table_id}`
WHERE is_violation = TRUE
"""

print("🚀 Fetching verified violation data from BigQuery...")
df_violators = client.query(query).to_dataframe()

# Check if we actually got data
if df_violators.empty:
    print("❌ Check failed: No records found with is_violation = TRUE.")
    print("Verify your BigQuery table: pay-errors.otpay.top_5_agencies_labels")
else:
    print(f"✅ Success! Analyzing {len(df_violators):,} records of confirmed managerial OT violations.")

    # --- STEP 1: THE STATISTICAL SNAPSHOT ---
    # We focus on the money paid and the hours worked
    snapshot = df_violators[['base_salary', 'total_ot_paid', 'ot_hours']].describe()

    # --- STEP 2: THE IQR OUTLIER TEST ---
    # Identifying the "Whales" in the dataset
    Q1 = df_violators['total_ot_paid'].quantile(0.25)
    Q3 = df_violators['total_ot_paid'].quantile(0.75)
    IQR = Q3 - Q1

    # Define the 'Statistical Outlier' boundary
    upper_bound = Q3 + (1.5 * IQR)

    # Filter for the extreme offenders
    extreme_outliers = df_violators[df_violators['total_ot_paid'] > upper_bound].sort_values(by='total_ot_paid', ascending=False)

    # Calculate Total Financial Exposure for these outliers
    total_outlier_cost = extreme_outliers['total_ot_paid'].sum()

    # --- DISPLAY RESULTS ---
    print("\n" + "📊 " + "="*40)
    print("PHASE 3: STATISTICAL AUDIT SUMMARY")
    print("="*42)
    print(snapshot)

    print("\n" + "🚨 " + "="*40)
    print("EXTREME OUTLIER REPORT (THE 'WALL OF SHAME')")
    print("="*42)
    print(f"Statistical Outlier Threshold: ${upper_bound:,.2f}")
    print(f"Total Outliers Detected: {len(extreme_outliers)}")
    print(f"Total Taxpayer Loss from Outliers: ${total_outlier_cost:,.2f}")

    print("\nTop 5 Offenders for Phase 4 Visualization:")
    # Displaying relevant columns for the final report
    cols_to_show = ['agency_name', 'title_description', 'total_ot_paid', 'ot_hours']
    print(extreme_outliers[cols_to_show].head(5))


