import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt
import numpy as np

# 1. PREP THE DATA FOR MATH
# We create a copy so we don't mess up our original DataFrame
corr_df = df_violators.copy()

# Convert Date to Tenure (Numerical)
corr_df['agency_start_date'] = pd.to_datetime(corr_df['agency_start_date'], errors='coerce')
corr_df['years_tenure'] = 2026 - corr_df['agency_start_date'].dt.year

# 2. SELECT THE KEY AUDIT VARIABLES
# We include numerical columns and "Dummy" variables for the categories
# This turns 'Borough' into 'Borough_Manhattan', 'Borough_Brooklyn', etc.
analysis_cols = ['total_ot_paid', 'base_salary', 'years_tenure', 'ot_hours',
                 'work_location_borough', 'agency_name', 'leave_status']

# Convert categories to numbers (One-Hot Encoding)
final_corr_df = pd.get_dummies(corr_df[analysis_cols], columns=['work_location_borough', 'agency_name', 'leave_status'])

# 3. CALCULATE THE CORRELATION MATRIX
matrix = final_corr_df.corr()

# 4. VISUALIZE THE HEATMAP
plt.figure(figsize=(16, 10))
sns.set_theme(style="white")

# We use a diverging palette: Red for positive correlation, Blue for negative
mask = np.triu(np.ones_like(matrix, dtype=bool)) # Hides the top half for a cleaner "Triangle" look
sns.heatmap(matrix, mask=mask, annot=False, cmap='coolwarm', center=0, linewidths=.5)

plt.title('The Audit Heatmap: Identifying Hidden Drivers of Illegal OT', fontsize=18, fontweight='bold')
plt.show()

# 5. THE "NEAT LIST" OF DRIVERS
# Focus only on what correlates with 'total_ot_paid'
print("\n" + "🔍 " + "="*50)
print("TOP DRIVERS OF ILLEGAL OVERTIME (CORRELATION TO PAYOUT)")
print("="*54)
payout_drivers = matrix['total_ot_paid'].sort_values(ascending=False)

# Filter for the top 10 most significant relationships (positive or negative)
print(payout_drivers.head(10))
print("\n... and the strongest inverse relationships:")
print(payout_drivers.tail(5))
